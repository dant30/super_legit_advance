{
  "compilerOptions": {
    /* Base Configuration */
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    
    /* Module Resolution */
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    
    /* Path Aliases */
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@components/customers": ["src/features/customers/components/index.js"],
      "@components/customers/*": ["src/features/customers/components/*"],
      "@components/loans": ["src/features/loans/components/index.js"],
      "@components/loans/*": ["src/features/loans/components/*"],
      "@components/repayments": ["src/features/repayments/components/index.js"],
      "@components/repayments/*": ["src/features/repayments/components/*"],
      "@components/notifications": ["src/features/notifications/components/index.js"],
      "@components/notifications/*": ["src/features/notifications/components/*"],
      "@components/dashboard": ["src/features/dashboard/components/index.js"],
      "@components/dashboard/*": ["src/features/dashboard/components/*"],
      "@components/admin/roles": ["src/features/admin/roles/components/index.js"],
      "@components/admin/roles/*": ["src/features/admin/roles/components/*"],
      "@components/admin/staff": ["src/features/admin/staff/components/index.js"],
      "@components/admin/staff/*": ["src/features/admin/staff/components/*"],
      "@components/admin/audit": ["src/features/admin/audit/components/index.js"],
      "@components/admin/audit/*": ["src/features/admin/audit/components/*"],
      "@components/admin/*": ["src/features/admin/*"],
      "@components/*": ["src/shared/components/*"],
      "@pages/*": ["src/features/*"],
      "@hooks/*": ["src/features/auth/hooks/*"],
      "@utils/*": ["src/shared/utils/*"],
      "@api/axios": ["src/core/api/axios.js"],
      "@api/admin": ["src/features/admin/dashboard/services/admin.js"],
      "@api/audit": ["src/features/admin/audit/services/audit.js"],
      "@api/auth": ["src/features/auth/services/auth.js"],
      "@api/customers": ["src/features/customers/services/customers.js"],
      "@api/loans": ["src/features/loans/services/loans.js"],
      "@api/mpesa": ["src/features/repayments/services/mpesa.js"],
      "@api/notifications": ["src/features/notifications/services/notifications.js"],
      "@api/repayments": ["src/features/repayments/services/repayments.js"],
      "@api/reports": ["src/features/reports/services/reports.js"],
      "@api/*": ["src/core/api/*"],
      "@styles/*": ["src/styles/*"],
      "@router/*": ["src/core/router/*"],
      "@contexts/*": ["src/core/contexts/*"]
    },
    
    /* Output */
    "noEmit": true,
    "allowJs": true,
    "checkJs": false,  /* ← This is CRITICAL: disable JS type checking */
    
    /* Interop */
    "skipLibCheck": true
  },
  
  "include": [
    "src/**/*.js",
    "src/**/*.jsx",
    "vite.config.js"
  ],
  
  "exclude": [
    "node_modules",
    "dist",
    "build",
    "coverage",
    "**/*.ts",
    "**/*.tsx"  /* ← Explicitly exclude TypeScript files */
  ]
}
